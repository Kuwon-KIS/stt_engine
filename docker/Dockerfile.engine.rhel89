# ============================================================================
# STT Engine - RHEL 8.9 Optimized with CUDA 12.9 + cuDNN
# 
# Build Platform: RHEL 8.9 AMI EC2
# Build Environment: Online (requires internet)
# Target Server: RHEL 8.9 with CUDA 12.9 + NVIDIA Driver 575.57.08
# Base Image: ubi8/python-311 (Red Hat Universal Base Image)
# glibc: 2.28 (RHEL 8.9 기본값 - 호환성 100%)
# cuDNN: wheel 패키지 설치
# Final Size: ~1.5GB (compressed tar.gz ~500MB)
#
# 빌드 명령어:
#   docker build --platform linux/amd64 -t stt-engine:cuda129-rhel89-v1.2 -f docker/Dockerfile.engine.rhel89 .
# ============================================================================

FROM --platform=linux/amd64 registry.access.redhat.com/ubi8/python-311:latest

LABEL maintainer="STT Engine Team"
LABEL description="STT Engine RHEL 8.9 Optimized with CUDA 12.9"
LABEL os="RHEL 8.9"
LABEL glibc="2.28"
LABEL cuda.version="12.9"
LABEL cudnn.version="9.0.0.312"
LABEL pytorch.version="2.6.0"

# 💡 중요: UBI 8 이미지는 기본으로 non-root 사용자로 설정됨
# FROM 바로 다음에 root로 전환하여 이후 모든 RUN 블록이 root 권한으로 실행되도록 함
USER root

# ============================================================================
# Step 1: Subscription Manager 완전 비활성화 + Rootless 사용자 생성
# ============================================================================

# 💡 모든 root 권한 작업을 한 RUN 블록에서 수행 (권한 문제 방지)
RUN rm -rf /etc/rhsm /etc/pki/entitlement* 2>/dev/null || true && \
    subscription-manager clean 2>/dev/null || true && \
    yum clean all 2>/dev/null || true && \
    rm -rf /var/cache/yum/* && \
    # Non-root 사용자 생성 (조건부: 존재하지 않으면 UID 2000으로 생성)
    (id stt-user >/dev/null 2>&1 || useradd -m -u 2000 -s /bin/bash stt-user) && \
    # sudo 권한 부여
    mkdir -p /etc/sudoers.d && \
    echo "stt-user ALL=(ALL) NOPASSWD: /usr/bin/yum" >> /etc/sudoers.d/stt-user && \
    chmod 0440 /etc/sudoers.d/stt-user

# ============================================================================
# Step 2: 시스템 의존성 설치 (아직 root로 실행 중)
# ============================================================================

RUN yum install -y \
    # CA 인증서 (SSL/TLS)
    ca-certificates \
    openssl \
    curl \
    wget \
    jq \
    \
    # Audio/Media 처리 (Python librosa로 대체)
    libsndfile \
    \
    # 개발 도구
    make \
    gcc \
    gcc-c++ \
    && yum clean all \
    && rm -rf /var/cache/yum/*

# ============================================================================
# Step 3: 애플리케이션 디렉토리 생성 (root로 실행)
# ============================================================================

WORKDIR /app

# 애플리케이션 디렉토리 구조 생성
RUN mkdir -p /app/models /app/logs /app/audio && \
    chmod -R 755 /app

# ============================================================================
# Step 4: cuDNN wheel 설치 (nvidia-cudnn-cu12) - ROOT로 실행
# 
# RHEL 8.9에서 pip를 통한 cuDNN 설치
# 버전: 9.0.0.312 (CUDA 12.x 호환)
# ============================================================================

RUN python3.11 -m pip install --upgrade nvidia-cudnn-cu12==9.0.0.312 && \
    ln -sf /opt/app-root/lib/python3.11/site-packages/nvidia/cudnn/lib/libcudnn.so.8 \
           /opt/app-root/lib/python3.11/site-packages/nvidia/cudnn/lib/libcudnn.so.9 && \
    ln -sf /opt/app-root/lib64/python3.11/site-packages/nvidia/cudnn/lib/libcudnn.so.8 \
           /opt/app-root/lib64/python3.11/site-packages/nvidia/cudnn/lib/libcudnn.so.9

# ============================================================================
# Step 5: Python 패키지 매니저 업그레이드 - ROOT로 실행
# ============================================================================

RUN python3.11 -m pip install --upgrade \
    --trusted-host pypi.org \
    --trusted-host files.pythonhosted.org \
    pip setuptools wheel

# ============================================================================
# Step 6: PyTorch 및 CUDA 런타임 라이브러리 설치 (먼저 설치) - ROOT로 실행
# 
# PyTorch 2.8.0 사용 - cu129 (CUDA 12.9) 공식 지원
# PyTorch 2.6.0은 cu129 인덱스에서 사용 불가 (cu124만 지원)
# torchaudio도 포함 (whisper에서 필수)
#
# *** 중요: PyTorch를 먼저 설치하는 이유 ***
# openai-whisper (20231117)는 triton<3,>=2.0.0을 요구
# torch 2.8.0은 triton==3.2.0을 요구
# PyTorch를 먼저 설치해야 openai-whisper가 이미 설치된 triton 3.2.0을 사용
# ============================================================================

RUN python3.11 -m pip install \
    --index-url https://download.pytorch.org/whl/cu129 \
    torch==2.8.0 \
    torchaudio==2.8.0

# ============================================================================
# ============================================================================
# Step 7: pip + setuptools + wheel 업그레이드 (모든 패키지 설치 준비)
# ============================================================================
# pip를 먼저 업그레이드 → 최신 pip로 setuptools/wheel 설치
# setuptools의 pkg_resources가 librosa(transformers 백엔드)에서 필요함
# ROOT 권한으로 실행 (USER 전환 전)
RUN python3.11 -m pip install --no-cache-dir --upgrade pip && \
    python3.11 -m pip install --no-cache-dir --upgrade --force-reinstall 'setuptools>=68.0' wheel

# ============================================================================
# Step 8: 모든 애플리케이션 의존성 설치 (모든 백엔드 활용 가능)
# ============================================================================
# PyTorch 2.8.0이 이미 설치됨 (Step 7)
# setuptools>=68.0이 이미 설치됨 (Step 8)
# pip가 최신이므로 모든 패키지 빌드 정상 작동:
#   - faster-whisper==1.2.1 (CTranslate2 백엔드, 가장 빠름)
#   - openai-whisper>=20240101 (공식 백엔드, 유연함)
#   - transformers (HuggingFace 백엔드, 상세 제어 가능)
# stt_engine.py의 WhisperSTT는 자동으로 백엔드 선택:
#   faster-whisper → transformers → openai-whisper
COPY --chown=root:root requirements.txt /tmp/

RUN python3.11 -m pip install \
    --no-cache-dir \
    -r /tmp/requirements.txt && \
    rm -f /tmp/requirements.txt

# ============================================================================
# Step 9: CUDA 라이브러리 위치 탐색 및 경로 등록
# ============================================================================

# Create ldconfig config file with ALL CUDA library paths
RUN echo "/opt/app-root/lib/python3.11/site-packages/nvidia/cudnn/lib" > /etc/ld.so.conf.d/torch-cuda.conf && \
    echo "/opt/app-root/lib/python3.11/site-packages/nvidia/cusparse/lib" >> /etc/ld.so.conf.d/torch-cuda.conf && \
    echo "/opt/app-root/lib/python3.11/site-packages/nvidia/cusparselt/lib" >> /etc/ld.so.conf.d/torch-cuda.conf && \
    echo "/opt/app-root/lib/python3.11/site-packages/nvidia/cublas/lib" >> /etc/ld.so.conf.d/torch-cuda.conf && \
    echo "/opt/app-root/lib/python3.11/site-packages/nvidia/cuda_runtime/lib" >> /etc/ld.so.conf.d/torch-cuda.conf && \
    echo "/opt/app-root/lib/python3.11/site-packages/cusparselt/lib" >> /etc/ld.so.conf.d/torch-cuda.conf && \
    echo "/opt/app-root/lib/python3.11/site-packages/torch/lib" >> /etc/ld.so.conf.d/torch-cuda.conf && \
    echo "/usr/local/lib" >> /etc/ld.so.conf.d/torch-cuda.conf && \
    echo "/usr/local/lib64" >> /etc/ld.so.conf.d/torch-cuda.conf

# Find and link CUDA libraries from nvidia/* and cusparselt/lib, rebuild ldconfig cache
RUN mkdir -p /usr/local/lib /usr/local/lib64 && \
    find /opt/app-root -path "*/site-packages/nvidia/*" -name "*.so*" -type f 2>/dev/null | while read lib; do \
        ln -sf "$lib" "/usr/local/lib/$(basename "$lib")" 2>/dev/null || true; \
        ln -sf "$lib" "/usr/local/lib64/$(basename "$lib")" 2>/dev/null || true; \
    done && \
    find /opt/app-root -path "*/site-packages/cusparselt/*" -name "*.so*" -type f 2>/dev/null | while read lib; do \
        ln -sf "$lib" "/usr/local/lib/$(basename "$lib")" 2>/dev/null || true; \
        ln -sf "$lib" "/usr/local/lib64/$(basename "$lib")" 2>/dev/null || true; \
    done && \
    find /opt/app-root -path "*/site-packages/torch/lib/*" -name "*.so*" -type f 2>/dev/null | while read lib; do \
        ln -sf "$lib" "/usr/local/lib/$(basename "$lib")" 2>/dev/null || true; \
        ln -sf "$lib" "/usr/local/lib64/$(basename "$lib")" 2>/dev/null || true; \
    done && \
    ldconfig && \
    echo "=== CUDA Libraries Found ===" && \
    ldconfig -p | grep -E "libcusparseLt|libcublas|libcusparse|libcudart|libcudnn" | sort -u | head -30

# Set LD_LIBRARY_PATH for CUDA library discovery at runtime
# Include all paths where CUDA libraries are installed
ENV LD_LIBRARY_PATH="/opt/app-root/lib/python3.11/site-packages/nvidia/cudnn/lib:/opt/app-root/lib/python3.11/site-packages/nvidia/cusparse/lib:/opt/app-root/lib/python3.11/site-packages/nvidia/cusparselt/lib:/opt/app-root/lib/python3.11/site-packages/nvidia/cublas/lib:/opt/app-root/lib/python3.11/site-packages/nvidia/cuda_runtime/lib:/opt/app-root/lib/python3.11/site-packages/cusparselt/lib:/opt/app-root/lib/python3.11/site-packages/torch/lib:/usr/local/lib:/usr/local/lib64"

# ============================================================================
# Step 10: 라이브러리 검증 및 로깅
# ============================================================================

RUN echo "=== CUDA Library Verification ===" && \
    ldconfig -p | grep -E "libcusparseLt|libcudnn|libcublas" | head -10 || echo "Some libraries may not be in ldconfig cache yet"

# ============================================================================
# Step 11: 디렉토리 생성 및 권한 설정 (ROOT로 실행)
# 
# 주의: USER 전환 BEFORE 모든 디렉토리/권한 설정 완료
# ROOT 권한이 필요한 mkdir/chown은 USER 전환 전에 완료해야 함
# ============================================================================

RUN mkdir -p /opt/app-root/src/.cache && \
    mkdir -p /app/models && \
    mkdir -p /app/logs && \
    mkdir -p /app/audio && \
    mkdir -p /tmp && \
    chown -R stt-user:stt-user /opt/app-root/src/.cache && \
    chown -R stt-user:stt-user /app/models && \
    chown -R stt-user:stt-user /app/logs && \
    chown -R stt-user:stt-user /app/audio && \
    chown -R stt-user:stt-user /tmp && \
    chmod -R 755 /opt/app-root/src/.cache && \
    chmod -R 755 /app/models && \
    chmod -R 755 /app/logs && \
    chmod -R 755 /app/audio && \
    chmod 755 /app

USER stt-user

# ============================================================================
# Step 12: 애플리케이션 파일 복사 (stt-user 권한)
# ============================================================================

# 애플리케이션 파일 복사
COPY --chown=stt-user:stt-user main.py /app/
COPY --chown=stt-user:stt-user api_server.py /app/
COPY --chown=stt-user:stt-user stt_engine.py /app/
COPY --chown=stt-user:stt-user stt_utils.py /app/
COPY --chown=stt-user:stt-user requirements.txt /app/
COPY --chown=stt-user:stt-user api_server/ /app/api_server/
COPY --chown=stt-user:stt-user utils/ /app/utils/

# ============================================================================
# Step 12-1: 프롬프트 파일 복사 (Element Detection + Privacy Removal)
# ============================================================================
# 통합 프롬프트 디렉토리 - 모든 프롬프트 파일이 한곳에 관리됨
# - element_detection_qwen.prompt: Element Detection vLLM용 프롬프트
# - privacy_remover_default_v6.prompt: Privacy Removal 기본 프롬프트
# - privacy_remover_loosed_contact_v6.prompt: Privacy Removal 확장 프롬프트
# - 기타 버전별 프롬프트 파일들

COPY --chown=stt-user:stt-user api_server/services/prompts/ /app/api_server/services/prompts/

# Python 환경 변수
ENV PYTHONUNBUFFERED=1
ENV HF_HOME=/app/models
ENV STT_DEVICE=cpu

# ============================================================================
# Step 13: 헬스 체크 및 포트 노출
# ============================================================================

# Health check: 60초마다 체크, 10초 타임아웃, 3번 실패 시 unhealthy
HEALTHCHECK --interval=60s --timeout=10s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:8003/health || exit 1

# STT API 포트
EXPOSE 8003

# ============================================================================
# Step 14: 시작 명령어
# ============================================================================

CMD ["python3.11", "main.py"]
